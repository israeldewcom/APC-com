# Django Core
SECRET_KEY=your-super-secret-key-minimum-50-characters-long-change-immediately
DEBUG=False
ALLOWED_HOSTS=api.apcconnect.ng,localhost
CORS_ALLOWED_ORIGINS=https://app.apcconnect.ng,https://admin.apcconnect.ng

# Database
DB_NAME=apc_db
DB_USER=apc_user
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432
ANALYTICS_DB_NAME=apc_analytics

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=apc-media-production
AWS_S3_REGION_NAME=us-east-1

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@apcconnect.ng
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=APC Private Connect <noreply@apcconnect.ng>

# Firebase (Push Notifications)
FCM_SERVER_KEY=your-firebase-server-key
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# NIMC API (NIN Verification)
NIMC_API_BASE_URL=https://api.nimc.gov.ng/v1
NIMC_API_KEY=your-nimc-api-key
NIMC_API_SECRET=your-nimc-api-secret
NIN_VERIFICATION_ENABLED=True

# SMS (Termii Nigeria)
TERMII_API_KEY=your-termii-api-key

# Celery
CELERY_RESULT_BACKEND=django-db

# Monitoring
GRAFANA_PASSWORD=your-grafana-password
FLOWER_USER=admin
FLOWER_PASSWORD=your-flower-password

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Payment Gateway (Paystack)
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# Google Cloud Vision (Moderation)
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json

# Location (Google Maps)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=Africa/Lagos
USE_I18N=True
USE_L10N=True

# Multi-Tenant
DEFAULT_DOMAIN=apcconnect.ng
TENANT_SCHEMA_PREFIX=tenant

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Encryption
ENCRYPTION_SALT=your-encryption-salt-here

# Biometrics (face recognition)
FACE_RECOGNITION_TOLERANCE=0.6

# AI Assistant (OpenAI or local)
OPENAI_API_KEY=your-openai-key
AI_MODEL_PATH=/app/models/

# TURN server for WebRTC
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your-turn-username
TURN_PASSWORD=your-turn-password
